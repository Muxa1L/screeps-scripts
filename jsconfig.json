{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "checkJs": true,
        "strict": false,
        "noImplicitAny": false,
        "lib": ["ES2022"],
        "baseUrl": ".",
        "paths": {
            "src/*": ["src/*"]
        },
        "types": ["screeps", "node"]
    },
    "include": [
        "src/**/*.js",
        "scripts/**/*.js",
        "tests/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "coverage"
    ]
}
